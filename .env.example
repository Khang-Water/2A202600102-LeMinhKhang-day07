# Embedding provider selection for manual experiments
# EMBEDDING_PROVIDER=mock
# EMBEDDING_PROVIDER=local
EMBEDDING_PROVIDER=openai

# Optional: set cache directories for the local all-MiniLM-L6-v2 embedder
# HF_HOME=./.hf-cache
# SENTENCE_TRANSFORMERS_HOME=./.sentence-transformers

# Optional: OpenAI embedding configuration
# Optional: for ChromaDB persistence (bonus task)
# CHROMA_PERSIST_DIR=./chroma_data
